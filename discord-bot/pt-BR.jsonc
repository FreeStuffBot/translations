  // Welcome to FreeStuff!
  "settings2_main_1_first_time": "Bem-vindo ao FreeStuff!",

  // FreeStuff Settings
  "settings2_main_1_regular": "Configurações do FreeStuff",

  // Welcome back! Manage your subscriptions below. Click on a category (blue button) for more info and to change settings.\nNeed help? Check out our [support server]({invite}) or [guide]({guide})!
  "settings2_main_2_regular": "Bem-vindo de volta! Gerencie suas assinaturas abaixo. Clique em uma categoria (botão azul) para obter mais informações e alterar as configurações.\nPrecisa de ajuda? Confira nosso [servidor de suporte]({invite}) ou [guia]({guide})!",

  // Disable Auto Publish
  "settings_auto_publish_off_prompt": "Desativar publicação automática",

  // Auto Publish Disabled
  "settings_auto_publish_off_state": "Publicação automática desativada",

  // Enable Auto Publish
  "settings_auto_publish_on_prompt": "Ativar publicação automática",

  // Auto Publish Enabled
  "settings_auto_publish_on_state": "Publicação automática ativada",

  // Unfortunately Discord took our ability to preview your avatar. Click the link to see if it's working…
  "settings_botprofile_avatar_description": "Infelizmente, o Discord removeu a possibilidade de pré-visualizar seu avatar. Clique no link para verificar se está funcionando…",

  // This does not look like a url
  "settings_botprofile_avatar_invalid_url_1": "Isso não parece ser uma URL.",

  // Please make sure your image actually loads and the link starts with `http://` or `https://`
  "settings_botprofile_avatar_invalid_url_2": "Certifique-se de que sua imagem carregue corretamente e que o link comece com `http://` ou `https://`.",

  // Bot Avatar
  "settings_botprofile_avatar_label": "Avatar do bot",

  // Ayo what's that
  "settings_botprofile_avatar_url_too_long_1": "E aí, o que é isso?",

  // Your url is a little... excessive... A little... long, maybe. Could you try make it shorter maybe? Thanks :D
  "settings_botprofile_avatar_url_too_long_2": "Seu URL é um pouco... excessivo... Um pouco... longo, talvez. Você poderia tentar encurtá-lo? Obrigado :D",

  // Edit Avatar
  "settings_botprofile_btn_edit_avatar": "Editar avatar",

  // Edit Name
  "settings_botprofile_btn_edit_name": "Editar nome",

  // (missing)
  "settings_botprofile_name_description": "(ausente)",

  // Bot Name
  "settings_botprofile_name_label": "Nome do bot",

  // Uhhh, very sorry uhhh
  "settings_botprofile_name_too_long_1": "Uhhh, desculpe muito uhhh",

  // But your name can only be 32 characters long. Directive from above, nothing I can do about that, sorry.
  "settings_botprofile_name_too_long_2": "Mas seu nome só pode ter 32 caracteres. É uma diretriz superior, não posso fazer nada a respeito, desculpe.",

  // Avatar and Name
  "settings_botprofile_ui_1": "Avatar e Nome",

  // Customize the bot's name and profile picture when sending notifications. Due to limitations with Discord this custom profile only applies to free game notifications, not when using commands like `/settings` or `/free`.
  "settings_botprofile_ui_2": "Personalize o nome e a foto de perfil do bot ao enviar notificações. Devido a limitações do Discord, este perfil personalizado só se aplica a notificações de jogos gratuitos, não ao usar comandos como `/settings` ou `/free`.",

  // Edit Avatar and Name
  "settings_change_bot_profile": "Editar Avatar e Nome",

  // You have too many webhooks in {channel}! Please open the channel settings, go to integrations, delete some unused webhooks, and come back. This limitation is enforced by Discord, we cannot do anything about this unfortunately.
  "settings_channel_error_too_many_webhooks": "Você tem muitos webhooks em {channel}! Por favor, abra as configurações do canal, vá para integrações, exclua alguns webhooks não utilizados e volte. Essa limitação é imposta pelo Discord, infelizmente não podemos fazer nada a respeito.",

  // here
  "settings_channel_list_here": "aqui",

  // You have too many channels to show them all in the list below.
  "settings_channel_list_too_many": "Você tem canais demais para exibi-los todos na lista abaixo.",

  // Missing \"Embed Messages\" Permission
  "settings_channel_list_warning_missing_embed_messages": "Falta a permissão \"Enviar Mensagens com Embed\"",

  // Missing \"Manage Webhooks\" Permission
  "settings_channel_list_warning_missing_manage_webhooks": "Permissão "Gerenciar Webhooks" ausente",

  // Missing \"Send Messages\" Permission
  "settings_channel_list_warning_missing_send_messages": "Falta a permissão \"Enviar Mensagens\"",

  // Missing \"View Channel\" Permission
  "settings_channel_list_warning_missing_view_channel": "Falta a permissão \"Ver Canal\"",

  // You have waaaaay too many channels to show them all in the list below. How do you even find anything in here?
  "settings_channel_list_way_too_many": "Você tem canais demais para mostrar todos na lista abaixo. Como você consegue encontrar alguma coisa aqui?",

  // Change The Channel
  "settings_channel_ui_1": "Alterar o canal",

  // Below you'll find a list of all of your channels. Please pick one for me to send free games to!
  "settings_channel_ui_2_regular": "Abaixo você encontrará uma lista de todos os seus canais. Por favor, escolha um para eu enviar os jogos gratuitos!",

  // Below you'll find a list of most of your channels. You had so many I couldn't show them all at once. Please pick one for me to send free games to!
  "settings_channel_ui_2_too_many": "Abaixo você encontrará uma lista de todos os seus canais, mas como você tinha muitos canais não pude mostrar todos. Por favor, escolha um para eu enviar os jogos gratuitos!",

  // Below you'll find a list of a few of your channels. You have an enormous amount of channels in this server, you know this? So many in fact I could only show you a small selection of them. Please pick one for me to send free games to!
  "settings_channel_ui_2_way_too_many": "Abaixo você encontrará uma lista de todos os seus canais, mas como você tinha muitos, mas muitos canais, eu tive que selecionar apenas alguns para você. Por favor, escolha um para eu enviar os jogos gratuitos!",

  // Can't change channel to {channel}: Missing \"{permissions}\" permissions!
  "settings_channel_ui_missing_permissions": "Não foi possível mudar para o canal {channel}: Faltam as permissões "{permissions}"!",

  // If you cannot find your desired channel, run /settings in that very channel to force it to show up.
  "settings_channel_ui_too_many_channels_tip": "O canal que você deseja não está aparecendo? Digite esse comando no canal em que você está pensando para o vê na lista!",

  // Unknown channel
  "settings_channel_unknown_channel": "Canal desconhecido",

  // Other Settings
  "settings_conf_ui_1": "Outras configurações",

  // **Select Language** will change the language notifications are shown in. This will **not** change the language of commands like /settings or /free. These use the same language you are using Discord in. Translations are community provided and might contain errors.\n\n**Select Currency** will change the currency in notifications. With some prices may get converted from other currencies or websites and thus might not always be 100% accurate.
  "settings_conf_ui_2": "**Selecionar Linguagem** mudará a linguagem das notificações. Isso **não** mudará a língua dos comandos como /settings ou /free. Estes usam a mesma linguagem que você configurou no seu Discord. As traduções são providenciadas pela comunidade e podem conter erros.\n\n**Selecionar Moeda** mudará a moeda usada para exibir os preços nas notificações. Alguns valores são convertidos de outras moedas ou podem vir de outros sites, portanto, a conversão pode nem sempre ser 100% precisa.",

  // Change the currency in notifications. With some prices may get converted from other currencies or websites and thus might not always be 100% accurate.
  "settings_conf_ui_currency_description": "Altere a moeda nas notificações. Alguns preços podem ser convertidos de outras moedas ou sites e, portanto, podem não ser 100% precisos.",

  // Select Currency
  "settings_conf_ui_currency_label": "Selecione a moeda",

  // Change the language notifications are shown in. This will **not** change the language of commands like /settings or /free. These use the same language you are using Discord in. Translations are community provided and might contain errors.
  "settings_conf_ui_language_description": "Alterar o idioma em que as notificações são exibidas. Isso **não** alterará o idioma de comandos como /settings ou /free. Eles usam o mesmo idioma que você está usando no Discord. As traduções são fornecidas pela comunidade e podem conter erros.",

  // Select Language
  "settings_conf_ui_language_label": "Selecione o idioma",

